---
// SiteFooter component - Help center site footer
---

<footer class="bg-white text-sm/loose text-gray-950 dark:bg-gray-950 dark:text-white">
  <div class="flex gap-4 p-4 md:hidden max-w-2xl lg:max-w-5xl">
    <div class="flex flex-1 flex-col gap-10">
      <div>
        <h3 class="font-semibold">Zod Help</h3>
        <ul class="mt-4 grid gap-4">
          <li><a class="hover:underline" href="/">Help Center</a></li>
          <li><a class="hover:underline" href="https://zodagent.com" target="_blank">Main Site</a></li>
        </ul>
      </div>
    </div>
    <div class="flex flex-1 flex-col gap-10">
      <div>
        <h3 class="font-semibold">Resources</h3>
        <ul class="mt-4 grid gap-4">
          <li><a class="hover:underline" href="https://github.com/AR-92/zod-harness">GitHub</a></li>
          <li><a class="hover:underline" href="https://docs.zodagent.com" target="_blank">Documentation</a></li>
        </ul>
      </div>
    </div>
  </div>
  <div class="mx-auto hidden w-full grid-cols-2 justify-between gap-y-0 md:grid md:grid-cols-2 md:gap-6 md:gap-x-4 lg:gap-8 max-w-2xl lg:max-w-5xl">
    <div class="border-x border-b border-gray-950/5 py-10 pl-2 not-md:border-0 md:border-b-0 dark:border-white/10">
      <h3 class="font-semibold">Zod Help</h3>
      <ul class="mt-4 grid gap-4">
        <li><a class="hover:underline" href="/">Help Center</a></li>
        <li><a class="hover:underline" href="https://zodagent.com" target="_blank">Main Site</a></li>
      </ul>
    </div>
    <div class="border-x border-gray-950/5 py-10 pl-2 not-md:border-0 dark:border-white/10">
      <h3 class="font-semibold">Resources</h3>
      <ul class="mt-4 grid gap-4">
        <li><a class="hover:underline" href="https://github.com/AR-92/zod-harness">GitHub</a></li>
        <li><a class="hover:underline" href="https://docs.zodagent.com" target="_blank">Documentation</a></li>
      </ul>
    </div>
  </div>
</footer>
