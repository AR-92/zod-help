---
import '../styles/global.css';
import Navbar from '../components/Navbar.astro';
import Footer from '../components/Footer.astro';
import DocsSidebar from '../components/DocsSidebar.astro';
import DocsTableOfContents from '../components/DocsTableOfContents.astro';

interface Props {
  title?: string;
  showSidebar?: boolean;
  currentSlug?: string;
  groupedDocs?: Record<string, any[]>;
}

const {
  title = "Zod Help Center",
  showSidebar = true,
  currentSlug = '',
  groupedDocs = {},
} = Astro.props;
---

<!doctype html lang="en" class="dark">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="generator" content={Astro.generator} />
    <title>{title}</title>
  </head>
  <body class="overflow-x-hidden">
    <div class="isolate bg-white dark:bg-gray-950">
      <Navbar />

      <div class="grid min-h-dvh grid-cols-1 grid-rows-[1fr_1px_auto_1px_auto] pt-26.25 lg:grid-cols-[14rem_2.5rem_minmax(0,1fr)_2.5rem] lg:pt-14.25 xl:grid-cols-[14rem_2.5rem_minmax(0,1fr)_2.5rem]">
        {showSidebar && (
          <div class="relative col-start-1 row-span-full row-start-1 max-lg:hidden">
            <div class="absolute inset-0">
              <div class="sticky top-14.25 bottom-0 left-0 h-full max-h-[calc(100dvh-(var(--spacing)*14.25))] w-56 overflow-y-auto p-6">
                <DocsSidebar groupedDocs={groupedDocs} currentSlug={currentSlug} />
              </div>
            </div>
          </div>
        )}

        <div class="col-start-2 row-span-5 row-start-1 border-x border-x-(--pattern-fg) bg-[image:repeating-linear-gradient(315deg,_var(--pattern-fg)_0,_var(--pattern-fg)_1px,_transparent_0,_transparent_50%)] bg-[size:10px_10px] bg-fixed [--pattern-fg:var(--color-gray-950)]/5 max-lg:hidden dark:[--pattern-fg:var(--color-white)]/10"></div>

        <div class="row-start-1 grid lg:col-start-3">
          <div class="mx-auto grid w-full max-w-2xl grid-cols-1 gap-10 xl:max-w-5xl xl:grid-cols-[minmax(0,1fr)_14rem]">
            <div class="px-4 pt-10 pb-24 sm:px-6 xl:pr-0">
              <slot />
            </div>
            <div class="max-xl:hidden">
              <slot name="toc" />
            </div>
          </div>
        </div>

        <div class="col-start-4 row-span-5 row-start-1 border-x border-x-(--pattern-fg) bg-[image:repeating-linear-gradient(315deg,_var(--pattern-fg)_0,_var(--pattern-fg)_1px,_transparent_0,_transparent_50%)] bg-[size:10px_10px] bg-fixed [--pattern-fg:var(--color-gray-950)]/5 max-lg:hidden dark:[--pattern-fg:var(--color-white)]/10"></div>

        <div class="col-span-full col-start-2 row-start-2 h-px bg-gray-950/5 dark:bg-white/10"></div>

        <div class="row-start-3 lg:col-start-3">
          <Footer />
        </div>

        <div class="col-span-full col-start-2 row-start-4 h-px bg-gray-950/5 dark:bg-white/10"></div>

        <div class="row-start-5 grid lg:col-start-3">
          <div class="mx-auto flex w-full flex-col items-start gap-6 sm:flex-row sm:items-center sm:justify-between sm:gap-8 max-w-2xl lg:max-w-5xl px-2 py-10">
            <div class="flex flex-col gap-4 text-sm/6 text-gray-700 sm:flex-row sm:gap-2 sm:pr-4 dark:text-gray-400">
              <span>Copyright © 2026 Zod</span>
              <span class="max-sm:hidden">·</span>
              <a class="hover:underline" href="https://github.com/AR-92/zod-help">GitHub</a>
              <span class="max-sm:hidden">·</span>
              <a class="hover:underline" href="https://zodagent.com" target="_blank">zodagent.com</a>
            </div>
          </div>
        </div>
      </div>
    </div>
  </body>
</html>
